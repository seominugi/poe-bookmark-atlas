{
  "manifest_version": 3,
  "name": "북마크 아틀라스",
  "version": "0.1.0",
  "description": "POE 거래소 검색 북마크 + 히스토리 관리 — 시세 스냅샷 포함",
  "icons": { "16": "src/icons/icon16.png", "48": "src/icons/icon48.png", "128": "src/icons/icon128.png" },
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "https://poe.kakaogames.com/*",
    "https://seominugi.com/*"
  ],
  "optional_host_permissions": ["https://www.pathofexile.com/*"],
  "background": { "service_worker": "src/background/service-worker.js", "type": "module" },
  "action": { "default_title": "북마크 아틀라스", "default_popup": "src/popup/popup.html", "default_icon": { "16": "src/icons/icon16.png", "48": "src/icons/icon48.png", "128": "src/icons/icon128.png" } },
  "commands": {
    "toggle-panel": { "suggested_key": { "default": "Alt+B" }, "description": "패널 열기 / 접기" },
    "save-search": { "suggested_key": { "default": "Alt+S" }, "description": "현재 검색 저장" }
  },
  "content_scripts": [
    {
      "matches": ["https://poe.kakaogames.com/trade/*", "https://poe.kakaogames.com/trade2/*"],
      "js": ["src/content/page-bridge.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://poe.kakaogames.com/trade/*", "https://poe.kakaogames.com/trade2/*"],
      "js": ["src/content/content-main.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://poe.kakaogames.com/trade/*", "https://poe.kakaogames.com/trade2/*"],
      "js": ["src/content/stat-shortcut.js"],
      "run_at": "document_idle",
      "world": "MAIN"
    },
    {
      "matches": ["https://www.pathofexile.com/trade/*", "https://www.pathofexile.com/trade2/*"],
      "js": ["src/content/cross-site-receiver.js"],
      "run_at": "document_idle"
    }
  ]
}
